{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cap.local/schemas/canonical-model/events/messaging/message-delivery-updated.schema.json",
  "title": "CAP Message Delivery Updated Event",
  "description": "Specialized canonical event schema for message.delivery.updated events.",
  "allOf": [
    {
      "$ref": "../../canonical-event-envelope.schema.json"
    },
    {
      "type": "object",
      "required": ["event_type", "payload"],
      "properties": {
        "event_type": {
          "const": "message.delivery.updated"
        },
        "payload": {
          "type": "object",
          "required": ["status"],
          "properties": {
            "status": {
              "type": "string",
              "enum": [
                "accepted",
                "queued",
                "sent",
                "delivered",
                "read",
                "failed",
                "dead_lettered"
              ]
            }
          },
          "additionalProperties": true
        }
      }
    }
  ]
}
