{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://car.local/schemas/canonical-model/events/identity/identity-resolution-requested.schema.json",
  "title": "CAR Identity Resolution Requested Event",
  "description": "Specialized canonical event schema for identity.resolution.requested events.",
  "allOf": [
    {
      "$ref": "../../canonical-event-envelope.schema.json"
    },
    {
      "type": "object",
      "required": ["event_type", "payload"],
      "properties": {
        "event_type": {
          "const": "identity.resolution.requested"
        },
        "payload": {
          "type": "object",
          "required": ["status"],
          "properties": {
            "status": {
              "const": "unknown"
            }
          },
          "additionalProperties": true
        }
      }
    }
  ]
}
