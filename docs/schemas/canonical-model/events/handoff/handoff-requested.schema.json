{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cap.local/schemas/canonical-model/events/handoff/handoff-requested.schema.json",
  "title": "CAP Handoff Requested Event",
  "description": "Specialized canonical event schema for handoff.requested events.",
  "allOf": [
    {
      "$ref": "../../canonical-event-envelope.schema.json"
    },
    {
      "type": "object",
      "required": ["event_type", "payload", "actor_type"],
      "properties": {
        "event_type": {
          "const": "handoff.requested"
        },
        "actor_type": {
          "enum": ["agent", "system"]
        },
        "payload": {
          "type": "object",
          "required": ["reason"],
          "properties": {
            "queue": {
              "type": "string",
              "minLength": 1
            },
            "reason": {
              "type": "string",
              "minLength": 1
            }
          },
          "additionalProperties": true
        }
      }
    }
  ],
  "examples": [
    {
      "event_id": "evt_106",
      "schema_version": "v1alpha1",
      "event_type": "handoff.requested",
      "tenant_id": "tenant_acme",
      "workspace_id": "ws_support",
      "conversation_id": "conv_1",
      "session_id": "sess_1",
      "correlation_id": "corr_1",
      "causation_id": "evt_104",
      "occurred_at": "2026-03-17T12:00:06Z",
      "actor_type": "agent",
      "payload": {
        "queue": "human_support",
        "reason": "low_confidence"
      }
    }
  ]
}
