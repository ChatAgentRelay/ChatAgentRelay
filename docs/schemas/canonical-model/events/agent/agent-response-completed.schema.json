{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cap.local/schemas/canonical-model/events/agent/agent-response-completed.schema.json",
  "title": "CAP Agent Response Completed Event",
  "description": "Specialized canonical event schema for agent.response.completed events.",
  "allOf": [
    {
      "$ref": "../../canonical-event-envelope.schema.json"
    },
    {
      "type": "object",
      "required": ["event_type", "payload", "actor_type"],
      "properties": {
        "event_type": {
          "const": "agent.response.completed"
        },
        "actor_type": {
          "const": "agent"
        },
        "payload": {
          "type": "object",
          "required": ["text"],
          "properties": {
            "text": {
              "type": "string",
              "minLength": 1
            }
          },
          "additionalProperties": true
        }
      }
    }
  ],
  "examples": [
    {
      "event_id": "evt_104",
      "schema_version": "v1alpha1",
      "event_type": "agent.response.completed",
      "tenant_id": "tenant_acme",
      "workspace_id": "ws_support",
      "conversation_id": "conv_1",
      "session_id": "sess_1",
      "correlation_id": "corr_1",
      "causation_id": "evt_103",
      "occurred_at": "2026-03-17T12:00:04Z",
      "actor": {
        "id": "agent_support"
      },
      "actor_type": "agent",
      "payload": {
        "text": "Your order shipped yesterday."
      }
    }
  ]
}
