# =============================================================================
# Slack (required — no defaults; see packages/server/src/config.ts)
# =============================================================================

# Bot User OAuth token from your Slack app (starts with xoxb-).
SLACK_BOT_TOKEN=xoxb-your-bot-token

# App-level token with connections:write for Socket Mode (starts with xapp-).
SLACK_APP_TOKEN=xapp-your-app-token

# =============================================================================
# OpenAI
# =============================================================================

# API key for OpenAI-compatible chat completions (required — no default).
OPENAI_API_KEY=sk-your-api-key

# Model id for completions. Default: gpt-4o-mini
OPENAI_MODEL=gpt-4o-mini

# System message prepended to the assistant. Default: You are a helpful assistant.
OPENAI_SYSTEM_PROMPT=You are a helpful assistant.

# Optional. Custom base URL for an OpenAI-compatible API. Omit to use the default OpenAI endpoint.
# OPENAI_BASE_URL=https://api.openai.com/v1

# =============================================================================
# CAR (tenant, ledger, HTTP API, policy, streaming)
# =============================================================================

# Logical tenant id for CAR routing and ledger scoping. Default: default_tenant
CAR_TENANT_ID=default_tenant

# Workspace id within the tenant. Default: default_workspace
CAR_WORKSPACE_ID=default_workspace

# Route id used when dispatching to the OpenAI agent. Default: openai_agent
CAR_ROUTE_ID=openai_agent

# SQLite file path for the append-only ledger. Default: ./car-ledger.db
CAR_SQLITE_PATH=./car-ledger.db

# Enable streaming Slack updates while the model responds. Set to "false" to disable. Default: true (any value except "false" enables streaming)
CAR_STREAMING=true

# Minimum interval in milliseconds between streaming Slack updates. Default: 800
CAR_STREAMING_INTERVAL_MS=800

# Port for the CAR HTTP API (health, etc.). Default: 3000
CAR_API_PORT=3000

# Optional. Inline JSON string for middleware policy configuration. If set, takes precedence over CAR_POLICY_FILE. Omit if unused.
# CAR_POLICY_CONFIG={"routes":[...]}

# Optional. Path to a JSON file containing policy configuration. Ignored if CAR_POLICY_CONFIG is set. Omit if unused.
# CAR_POLICY_FILE=./policy.json

# Optional. Set to "debug" to enable debug-level log lines (packages/server/src/logger.ts). Omit for standard info/warn/error only.
# CAR_LOG_LEVEL=debug
